FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml ./
COPY src/ src/
COPY tests/ tests/

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir . \
    && pip install --no-cache-dir pytest \
    && rm -rf /root/.cache/pip

CMD ["python", "-m", "pytest", "tests/", "-v"]
