        "capabilities": ["protocol_adapt", "third_party_api", "custom_skill"]
      },
      {
        "project": "spidermax_room",
        "role": "虚拟协作空间",
        "register_as": "skill_plugin",
        "endpoint": "@register_skill 装饰器",
        "capabilities": ["multi_agent_collaboration", "room_management", "task_coordination"]
      }
    ]
  },
  "registration": {
    "description": "spider_meta 提供三种注册方式，适应不同集成深度",
    "methods": [
      {
        "type": "worker",
        "description": "注册可执行任务的 Worker 节点（爬虫、处理器等）",
        "endpoint": "POST http://{meta_host}:8003/workers/register",
        "request_body": {
          "worker_id": "string (唯一标识)",
          "skills": ["string (能力标签)"],
          "endpoint": "string (Worker API地址)"
        },
        "example": "curl -X POST http://localhost:8003/workers/register -H 'Content-Type: application/json' -d '{\"worker_id\":\"spider-max-01\",\"skills\":[\"crawl\",\"js_render\"],\"endpoint\":\"http://spider-max:8005\"}'",
        "used_by": ["mini_spider", "spider_max"]
      },
      {
        "type": "tool",
        "description": "注册功能性工具（知识检索、存储、外部API等）",
        "code": "from spider_meta.main import tools\ntools.register(name, func, description, parameters)",
        "example": "tools.register('kg_search', search_func, '知识图谱检索', {'query': 'string'})",
        "used_by": ["spider_diary", "知识图谱", "第三方API"]
      },
      {
        "type": "skill_plugin",
        "description": "注册复杂技能插件（有生命周期管理、参数验证）",
        "code": "@register_skill\nclass MySkill(SkillPlugin):\n    name = 'my_skill'\n    async def execute(self, task): ...",
        "used_by": ["Spider-X", "spidermax_room", "自定义扩展"]
      },
      {
        "type": "event_subscription",
        "description": "订阅系统事件，实现事件驱动的自动化流水线",
        "code": "from spider_meta.core.event_bus import event_bus\nevent_bus.subscribe([EventType.TASK_SUBMITTED], handler_func)",
        "example": "订阅 TASK_COMPLETED 事件触发下一个任务",
        "used_by": ["所有需要响应系统状态变化的项目"]
      }
    ]
  },
